# PostgreSQL database name used by Docker Compose.
POSTGRES_DB=""

# PostgreSQL username used by Docker Compose.
POSTGRES_USER=""

# PostgreSQL password used by Docker Compose.
POSTGRES_PASSWORD=""

# PostgreSQL connection string used by the Next.js app and migration script.
# Local non-Docker development usually uses localhost. Docker/Coolify should use the Compose service host, for example:
# DATABASE_URL="postgresql://addressbook:addressbook@db:5432/addressbook"
DATABASE_URL=""

# Public base URL of the app. In production this must be the deployed HTTPS URL.
NEXTAUTH_URL=""
# Secret used to sign session JWTs. Use a random string of at least 32 characters in production.
NEXTAUTH_SECRET=""
# Resend API key for sending email confirmation messages.
# In local development this can be empty; confirmation emails are logged to the server console.
RESEND_API_KEY=""

# Sender email address used for confirmation messages.
# Required when RESEND_API_KEY is configured.
FROM_EMAIL=""

# Bearer-token secret protecting /api/cron/cleanup-pending.
# Set this in production if an external scheduler will call the cleanup endpoint.
CRON_SECRET=""
